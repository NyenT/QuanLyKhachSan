# ------------------------------------------------
# Visual Studio / .NET gitignore (chuẩn Microsoft)
# ------------------------------------------------

# Build results
[Dd]ebug/
[Dd]ebugPublic/
[Rr]elease/
[Rr]eleases/
x64/
x86/
[Ww][Ii][Nn]32/
[Aa][Rr][Mm]/
[Aa][Rr][Mm]64/
bld/
[Bb]in/
[Oo]bj/
[Ll]og/
[Ll]ogs/

# Visual Studio 2015/2017 cache/options directory
.vs/
# Visual Studio Code
.vscode/

# NuGet
*.nupkg
*.snupkg
**/[Pp]ackages/*
!**/[Pp]ackages/build/

# User-specific files
*.rsuser
*.suo
*.user
*.userosscache
*.sln.docstates
*.userprefs

# Build results of ATL projects
[Dd]ebugPS/
[Rr]eleasePS/
dlldata.c

# IIS / IIS Express
.iisexpress.json

# JetBrains Rider
.idea/
*.sln.iml

# Backup & report files
_UpgradeReport_Files/
Backup*/
UpgradeLog*.XML
UpgradeLog*.htm

# SQLite database file - CHÚ Ý: nếu muốn commit DB mẫu thì xoá dòng dưới
# Khuyến nghị: KHÔNG commit file .db vì chứa dữ liệu thử nghiệm.
*.db
*.db-shm
*.db-wal
*.sqlite
*.sqlite3

# macOS / Windows metadata
.DS_Store
Thumbs.db
ehthumbs.db
desktop.ini

# Tạm thời
*.tmp
*.bak
